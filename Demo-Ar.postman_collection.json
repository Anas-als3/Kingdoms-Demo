{
  "info": {
    "name": "Kingdom — Demo (Ar)",
    "description": "مسار العرض الكامل بالعربية. الدخول بلاعب مُسجَّل مسبقاً (player2/demo1234 = عبدالله) — التسجيل متخطّى. لكل مملكة: انضم ← صادِق إن لزم ← تصفّح ← انضم للتحدّي ← أنهِ. ثم اللوبي (صورة AI) ثم الملف/الأوسمة/الصدارة. baseUrl الافتراضي محلي.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{playerUser}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{playerPass}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "playerUser",
      "value": "player2"
    },
    {
      "key": "playerPass",
      "value": "demo1234"
    },
    {
      "key": "challengeId",
      "value": ""
    },
    {
      "key": "progressId",
      "value": ""
    },
    {
      "key": "membershipId",
      "value": ""
    },
    {
      "key": "lobbyChallengeId",
      "value": ""
    },
    {
      "key": "lobbyId",
      "value": ""
    },
    {
      "key": "lobbyProgressId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "٠ — الدخول (لاعب مُسجَّل مسبقاً)",
      "item": [
        {
          "name": "ملفّي — تأكيد الدخول كـ عبدالله",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/player/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "player",
                "me"
              ]
            },
            "description": "بدون تسجيل: الدخول بحساب لاعب مُسجَّل مُسبقاً  player2 / demo1234 = عبدالله (Premium). كل الطلبات تعمل بهذا الدخول إلا ما حُدّد غير ذلك."
          }
        }
      ]
    },
    {
      "name": "مملكة الرياضة",
      "item": [
        {
          "name": "انضم لـ مملكة الرياضة",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/kingdom-membership/join/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "kingdom-membership",
                "join",
                "1"
              ]
            },
            "description": "الانضمام للمملكة. (عبدالله Premium فلا يوجد حدّ للممالك.)"
          }
        },
        {
          "name": "تفويض سترافا (المصادقة المطلوبة)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/verify/fitness/connect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verify",
                "fitness",
                "connect"
              ]
            },
            "description": "يرجع authorizeUrl — افتحه في المتصفح ووافق على Strava، ثم أنهِ التحدّي."
          }
        },
        {
          "name": "تصفّح تحديات الرياضة",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/challenge/kingdom/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "challenge",
                "kingdom",
                "1"
              ]
            },
            "description": "يحفظ أول تحدٍّ في المتغيّر challengeId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var a; try{a=pm.response.json()}catch(e){a=[]}",
                  "if(Array.isArray(a)&&a.length&&a[0].id!=null)pm.collectionVariables.set('challengeId',a[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "انضم للتحدّي",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/challenge-progress/join/{{challengeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "challenge-progress",
                "join",
                "{{challengeId}}"
              ]
            },
            "description": "يحفظ progressId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var j; try{j=pm.response.json()}catch(e){j={}}",
                  "if(j&&j.progressId!=null)pm.collectionVariables.set('progressId',j.progressId);"
                ]
              }
            }
          ]
        },
        {
          "name": "أنهِ التحدّي (تحقّق)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/challenge-progress/finish/{{progressId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "challenge-progress",
                "finish",
                "{{progressId}}"
              ]
            },
            "description": "يتحقق من نشاطك الحقيقي ويمنح XP عند تحقّق الهدف."
          }
        }
      ]
    },
